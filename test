<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Purple Glow UI Preview</title>
  <style>
    :root {
      --bg-1: #0a0612;
      --bg-2: #13081d;
      --panel: rgba(28, 16, 42, 0.78);
      --panel-strong: rgba(36, 19, 55, 0.92);
      --border: rgba(190, 120, 255, 0.35);
      --purple: #a855f7;
      --purple-2: #c084fc;
      --purple-3: #7c3aed;
      --text: #f5edff;
      --muted: #c9b4ea;
      --good: #4ade80;
      --warn: #f59e0b;
      --danger: #f87171;
      --shadow-lg:
        0 0 0 1px rgba(200, 145, 255, 0.15),
        0 0 18px rgba(168, 85, 247, 0.22),
        0 0 40px rgba(124, 58, 237, 0.14),
        inset 0 0 18px rgba(255, 255, 255, 0.03);
      --shadow-btn:
        0 0 0 1px rgba(210, 165, 255, 0.18),
        0 0 20px rgba(168, 85, 247, 0.2);
      --radius-xl: 28px;
      --radius-lg: 22px;
      --radius-md: 18px;
      --radius-sm: 14px;
    }

    * {
      box-sizing: border-box;
    }

    html, body {
      width: 100%;
      height: 100%;
      margin: 0;
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      color: var(--text);
      overflow: hidden;
      background:
        radial-gradient(circle at 15% 20%, rgba(168, 85, 247, 0.28), transparent 22%),
        radial-gradient(circle at 85% 18%, rgba(192, 132, 252, 0.22), transparent 20%),
        radial-gradient(circle at 70% 78%, rgba(124, 58, 237, 0.18), transparent 24%),
        linear-gradient(135deg, var(--bg-1), var(--bg-2) 55%, #12061d 100%);
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      background:
        radial-gradient(circle at center, rgba(168, 85, 247, 0.06), transparent 45%),
        repeating-linear-gradient(
          90deg,
          rgba(255,255,255,0.015) 0px,
          rgba(255,255,255,0.015) 1px,
          transparent 1px,
          transparent 90px
        ),
        repeating-linear-gradient(
          0deg,
          rgba(255,255,255,0.012) 0px,
          rgba(255,255,255,0.012) 1px,
          transparent 1px,
          transparent 90px
        );
      mix-blend-mode: screen;
      opacity: 0.7;
    }

    .app {
      width: 100%;
      height: 100%;
      padding: 26px;
      display: grid;
      grid-template-columns: 320px 1fr 360px;
      gap: 20px;
    }

    .panel {
      background: var(--panel);
      border: 1px solid var(--border);
      box-shadow: var(--shadow-lg);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-radius: var(--radius-xl);
      position: relative;
      overflow: hidden;
    }

    .panel::after {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      border-radius: inherit;
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.06);
    }

    .left-col,
    .center-col,
    .right-col {
      display: grid;
      gap: 20px;
      min-height: 0;
    }

    .left-col {
      grid-template-rows: 120px 1fr 210px;
    }

    .center-col {
      grid-template-rows: 90px 1fr 150px;
    }

    .right-col {
      grid-template-rows: 280px 1fr;
    }

    .brand {
      padding: 22px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      background:
        linear-gradient(180deg, rgba(168, 85, 247, 0.12), transparent),
        var(--panel);
    }

    .brand-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .logo {
      display: flex;
      align-items: center;
      gap: 14px;
    }

    .logo-badge {
      width: 56px;
      height: 56px;
      border-radius: 20px;
      background: radial-gradient(circle at 30% 30%, #d8b4fe, var(--purple));
      display: grid;
      place-items: center;
      color: white;
      font-weight: 900;
      font-size: 20px;
      box-shadow:
        0 0 24px rgba(168, 85, 247, 0.5),
        inset 0 0 20px rgba(255,255,255,0.18);
    }

    .logo-text h1 {
      margin: 0;
      font-size: 20px;
      line-height: 1;
      letter-spacing: 0.5px;
    }

    .logo-text p {
      margin: 6px 0 0;
      font-size: 12px;
      color: var(--muted);
    }

    .tag {
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(168, 85, 247, 0.12);
      border: 1px solid rgba(200, 145, 255, 0.25);
      color: var(--purple-2);
      font-size: 12px;
      font-weight: 700;
      box-shadow: 0 0 14px rgba(168, 85, 247, 0.16);
    }

    .brand-bottom {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }

    .mini-chip {
      padding: 8px 12px;
      background: rgba(255,255,255,0.03);
      border-radius: 999px;
      font-size: 12px;
      color: var(--muted);
      border: 1px solid rgba(255,255,255,0.05);
    }

    .section {
      padding: 20px;
      min-height: 0;
    }

    .section-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 16px;
      gap: 12px;
    }

    .section-title {
      margin: 0;
      font-size: 16px;
      font-weight: 800;
      letter-spacing: 0.3px;
    }

    .section-subtitle {
      font-size: 12px;
      color: var(--muted);
    }

    .inventory-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 12px;
    }

    .item {
      aspect-ratio: 1;
      border-radius: 20px;
      border: 1px solid rgba(192, 132, 252, 0.2);
      background:
        linear-gradient(180deg, rgba(168, 85, 247, 0.12), rgba(255,255,255,0.02)),
        rgba(255,255,255,0.025);
      box-shadow:
        0 0 16px rgba(168, 85, 247, 0.12),
        inset 0 0 12px rgba(255,255,255,0.03);
      padding: 10px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      cursor: pointer;
      transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
      user-select: none;
    }

    .item:hover {
      transform: translateY(-3px) scale(1.02);
      border-color: rgba(216, 180, 254, 0.4);
      box-shadow:
        0 0 24px rgba(168, 85, 247, 0.22),
        inset 0 0 14px rgba(255,255,255,0.04);
    }

    .item-icon {
      font-size: 22px;
      opacity: 0.95;
    }

    .item-name {
      font-size: 11px;
      font-weight: 700;
      color: #f7f1ff;
    }

    .item-count {
      font-size: 11px;
      color: var(--purple-2);
    }

    .quick-actions {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
      margin-top: 4px;
    }

    .btn {
      border: none;
      color: white;
      border-radius: 18px;
      padding: 14px 16px;
      font-weight: 800;
      font-size: 13px;
      letter-spacing: 0.2px;
      background:
        linear-gradient(135deg, rgba(168, 85, 247, 0.95), rgba(124, 58, 237, 0.95));
      box-shadow: var(--shadow-btn);
      cursor: pointer;
      transition: transform 0.18s ease, filter 0.18s ease, box-shadow 0.18s ease;
    }

    .btn:hover {
      transform: translateY(-2px);
      filter: brightness(1.08);
      box-shadow:
        0 0 0 1px rgba(225, 190, 255, 0.22),
        0 0 26px rgba(168, 85, 247, 0.3);
    }

    .btn.secondary {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(216, 180, 254, 0.18);
      color: var(--text);
    }

    .topbar {
      display: grid;
      grid-template-columns: 1fr auto auto auto;
      align-items: center;
      gap: 14px;
      padding: 18px 22px;
    }

    .searchbar {
      display: flex;
      align-items: center;
      gap: 12px;
      border-radius: 18px;
      background: rgba(255,255,255,0.035);
      padding: 14px 16px;
      border: 1px solid rgba(216, 180, 254, 0.14);
      box-shadow: inset 0 0 12px rgba(255,255,255,0.02);
    }

    .searchbar input {
      width: 100%;
      border: none;
      outline: none;
      background: transparent;
      color: var(--text);
      font-size: 14px;
    }

    .pill-stat {
      min-width: 100px;
      text-align: center;
      padding: 14px 16px;
      border-radius: 18px;
      background: rgba(255,255,255,0.035);
      border: 1px solid rgba(216, 180, 254, 0.14);
      box-shadow: inset 0 0 12px rgba(255,255,255,0.02);
    }

    .pill-stat .label {
      display: block;
      font-size: 10px;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 4px;
    }

    .pill-stat .value {
      font-size: 16px;
      font-weight: 800;
    }

    .dashboard {
      padding: 20px;
      display: grid;
      grid-template-columns: 1.25fr 0.9fr;
      gap: 20px;
      min-height: 0;
    }

    .stack {
      display: grid;
      gap: 20px;
      min-height: 0;
    }

    .character-card {
      padding: 20px;
      display: grid;
      grid-template-columns: 110px 1fr;
      gap: 18px;
      align-items: center;
      background:
        radial-gradient(circle at top left, rgba(192, 132, 252, 0.16), transparent 35%),
        var(--panel-strong);
      border-radius: 28px;
      border: 1px solid rgba(200, 145, 255, 0.24);
      box-shadow: var(--shadow-lg);
    }

    .avatar {
      width: 110px;
      height: 110px;
      border-radius: 28px;
      background:
        radial-gradient(circle at 30% 25%, #e9d5ff, #a855f7 42%, #5b21b6 100%);
      display: grid;
      place-items: center;
      font-size: 42px;
      font-weight: 900;
      box-shadow:
        0 0 25px rgba(168, 85, 247, 0.35),
        inset 0 0 24px rgba(255,255,255,0.22);
    }

    .character-info h2 {
      margin: 0 0 8px;
      font-size: 22px;
    }

    .character-info p {
      margin: 0 0 14px;
      color: var(--muted);
      font-size: 13px;
    }

    .meta-row {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .meta-chip {
      padding: 10px 12px;
      border-radius: 999px;
      font-size: 12px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(216, 180, 254, 0.16);
      color: #f3e8ff;
    }

    .job-menu {
      padding: 20px;
    }

    .job-list {
      display: grid;
      gap: 12px;
    }

    .job-row {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 14px;
      align-items: center;
      padding: 14px;
      border-radius: 20px;
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(216, 180, 254, 0.14);
      transition: transform 0.18s ease, border-color 0.18s ease, background 0.18s ease;
    }

    .job-row:hover,
    .job-row.active {
      transform: translateX(2px);
      background: rgba(168, 85, 247, 0.1);
      border-color: rgba(216, 180, 254, 0.28);
    }

    .job-row h4 {
      margin: 0 0 5px;
      font-size: 14px;
    }

    .job-row p {
      margin: 0;
      color: var(--muted);
      font-size: 12px;
    }

    .job-badge {
      padding: 10px 12px;
      border-radius: 14px;
      font-size: 12px;
      font-weight: 800;
      background: rgba(168, 85, 247, 0.18);
      color: #ead7ff;
      border: 1px solid rgba(216, 180, 254, 0.2);
    }

    .footer-actions {
      padding: 20px;
      display: flex;
      gap: 12px;
      align-items: stretch;
    }

    .footer-actions .btn {
      flex: 1;
    }

    .phone {
      padding: 20px;
      display: grid;
      grid-template-rows: auto 1fr auto;
      gap: 14px;
      min-height: 0;
    }

    .phone-shell {
      height: 100%;
      border-radius: 34px;
      padding: 14px;
      background:
        linear-gradient(180deg, rgba(168, 85, 247, 0.12), rgba(255,255,255,0.025)),
        rgba(12, 8, 20, 0.9);
      border: 1px solid rgba(216, 180, 254, 0.16);
      box-shadow:
        0 0 28px rgba(168, 85, 247, 0.16),
        inset 0 0 20px rgba(255,255,255,0.03);
      display: grid;
      grid-template-rows: auto 1fr auto;
      gap: 12px;
      min-height: 0;
    }

    .phone-top {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 4px 6px 0;
      font-size: 12px;
      color: var(--muted);
    }

    .apps {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
      align-content: start;
    }

    .app-icon {
      border-radius: 22px;
      padding: 14px 10px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(216, 180, 254, 0.14);
      text-align: center;
      box-shadow: inset 0 0 10px rgba(255,255,255,0.03);
      cursor: pointer;
      transition: transform 0.18s ease, background 0.18s ease;
    }

    .app-icon:hover {
      transform: translateY(-2px);
      background: rgba(168, 85, 247, 0.14);
    }

    .app-icon .emoji {
      display: block;
      font-size: 24px;
      margin-bottom: 8px;
    }

    .app-icon span:last-child {
      font-size: 11px;
      color: var(--text);
      font-weight: 700;
    }

    .notify-list {
      display: grid;
      gap: 12px;
      padding: 20px;
      min-height: 0;
      overflow: auto;
    }

    .notify {
      padding: 14px;
      border-radius: 20px;
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(216, 180, 254, 0.14);
      box-shadow: inset 0 0 12px rgba(255,255,255,0.02);
      animation: popIn 0.25s ease;
    }

    .notify strong {
      display: block;
      font-size: 13px;
      margin-bottom: 6px;
    }

    .notify p {
      margin: 0;
      font-size: 12px;
      color: var(--muted);
      line-height: 1.45;
    }

    .hud {
      padding: 18px 20px;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
      align-items: center;
    }

    .hud-card {
      padding: 12px 14px;
      border-radius: 20px;
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(216, 180, 254, 0.14);
      box-shadow:
        inset 0 0 12px rgba(255,255,255,0.03),
        0 0 12px rgba(168, 85, 247, 0.08);
    }

    .hud-title {
      font-size: 11px;
      color: var(--muted);
      margin-bottom: 10px;
      text-transform: uppercase;
      letter-spacing: 0.8px;
    }

    .bar {
      width: 100%;
      height: 10px;
      border-radius: 999px;
      background: rgba(255,255,255,0.05);
      overflow: hidden;
      box-shadow: inset 0 0 10px rgba(0,0,0,0.2);
    }

    .bar-fill {
      height: 100%;
      border-radius: inherit;
      background: linear-gradient(90deg, #c084fc, #7c3aed);
      box-shadow: 0 0 16px rgba(168, 85, 247, 0.35);
      transition: width 0.25s ease;
    }

    .bar-fill.health { width: 84%; }
    .bar-fill.armor { width: 52%; }
    .bar-fill.stamina { width: 73%; }
    .bar-fill.voice { width: 39%; }

    .tiny {
      margin-top: 8px;
      font-size: 11px;
      color: #f3e8ff;
      font-weight: 700;
    }

    .toast-wrap {
      position: fixed;
      top: 24px;
      right: 24px;
      display: grid;
      gap: 12px;
      z-index: 9999;
      pointer-events: none;
    }

    .toast {
      min-width: 280px;
      max-width: 360px;
      padding: 14px 16px;
      border-radius: 20px;
      background: rgba(19, 12, 30, 0.94);
      border: 1px solid rgba(216, 180, 254, 0.18);
      box-shadow:
        0 0 24px rgba(168, 85, 247, 0.24),
        inset 0 0 12px rgba(255,255,255,0.03);
      animation: slideIn 0.26s ease;
      pointer-events: auto;
    }

    .toast strong {
      display: block;
      margin-bottom: 6px;
      font-size: 13px;
    }

    .toast p {
      margin: 0;
      color: var(--muted);
      font-size: 12px;
      line-height: 1.4;
    }

    .hidden-ui {
      opacity: 0;
      transform: scale(0.985);
      pointer-events: none;
      transition: all 0.25s ease;
    }

    .app.visible {
      opacity: 1;
      transform: scale(1);
      transition: all 0.25s ease;
    }

    @keyframes slideIn {
      from {
        opacity: 0;
        transform: translateY(-10px) translateX(16px);
      }
      to {
        opacity: 1;
        transform: translateY(0) translateX(0);
      }
    }

    @keyframes popIn {
      from {
        opacity: 0;
        transform: translateY(8px) scale(0.98);
      }
      to {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }

    @media (max-width: 1300px) {
      body {
        overflow: auto;
      }

      .app {
        min-height: 100vh;
        grid-template-columns: 1fr;
      }

      .left-col,
      .center-col,
      .right-col {
        grid-template-rows: auto;
      }

      .dashboard {
        grid-template-columns: 1fr;
      }

      .hud {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 700px) {
      .inventory-grid {
        grid-template-columns: repeat(3, 1fr);
      }

      .topbar {
        grid-template-columns: 1fr;
      }

      .hud {
        grid-template-columns: 1fr;
      }

      .character-card {
        grid-template-columns: 1fr;
        text-align: center;
      }

      .meta-row {
        justify-content: center;
      }
    }
  </style>
</head>
<body>
  <div class="toast-wrap" id="toastWrap"></div>

  <main class="app visible" id="app">
    <section class="left-col">
      <div class="panel brand">
        <div class="brand-top">
          <div class="logo">
            <div class="logo-badge">V</div>
            <div class="logo-text">
              <h1>Violet Core</h1>
              <p>Rounded NUI Website Preview</p>
            </div>
          </div>
          <div class="tag">LIVE UI</div>
        </div>

        <div class="brand-bottom">
          <span class="mini-chip">Purple Glow</span>
          <span class="mini-chip">Rounded Layout</span>
          <span class="mini-chip">Standalone Preview</span>
        </div>
      </div>

      <div class="panel section">
        <div class="section-header">
          <div>
            <h3 class="section-title">Inventory</h3>
            <div class="section-subtitle">Click items to test notifications</div>
          </div>
          <div class="tag" id="weightTag">24 / 40 KG</div>
        </div>

        <div class="inventory-grid" id="inventoryGrid">
          <div class="item" data-item="Bandage">
            <div class="item-icon">🩹</div>
            <div>
              <div class="item-name">Bandage</div>
              <div class="item-count">x6</div>
            </div>
          </div>
          <div class="item" data-item="Radio">
            <div class="item-icon">📻</div>
            <div>
              <div class="item-name">Radio</div>
              <div class="item-count">x1</div>
            </div>
          </div>
          <div class="item" data-item="Water">
            <div class="item-icon">💧</div>
            <div>
              <div class="item-name">Water</div>
              <div class="item-count">x4</div>
            </div>
          </div>
          <div class="item" data-item="Burger">
            <div class="item-icon">🍔</div>
            <div>
              <div class="item-name">Burger</div>
              <div class="item-count">x2</div>
            </div>
          </div>
          <div class="item" data-item="Pistol Ammo">
            <div class="item-icon">🔸</div>
            <div>
              <div class="item-name">Pistol Ammo</div>
              <div class="item-count">x42</div>
            </div>
          </div>
          <div class="item" data-item="Repair Kit">
            <div class="item-icon">🧰</div>
            <div>
              <div class="item-name">Repair Kit</div>
              <div class="item-count">x1</div>
            </div>
          </div>
          <div class="item" data-item="Lockpick">
            <div class="item-icon">🗝️</div>
            <div>
              <div class="item-name">Lockpick</div>
              <div class="item-count">x3</div>
            </div>
          </div>
          <div class="item" data-item="Cash">
            <div class="item-icon">💵</div>
            <div>
              <div class="item-name">Cash</div>
              <div class="item-count">$3,240</div>
            </div>
          </div>
        </div>
      </div>

      <div class="panel section">
        <div class="section-header">
          <div>
            <h3 class="section-title">Quick Actions</h3>
            <div class="section-subtitle">Mock buttons for preview</div>
          </div>
        </div>

        <div class="quick-actions">
          <button class="btn" id="notifyBtn">Push Notify</button>
          <button class="btn secondary" id="toggleUiBtn">Hide UI</button>
          <button class="btn secondary" id="healBtn">Heal</button>
          <button class="btn" id="payBtn">Paycheck</button>
        </div>
      </div>
    </section>

    <section class="center-col">
      <div class="panel topbar">
        <div class="searchbar">
          <span>🔎</span>
          <input type="text" id="fakeSearch" placeholder="Search players, jobs, items..." />
        </div>
        <div class="pill-stat">
          <span class="label">Cash</span>
          <span class="value" id="cashValue">$3,240</span>
        </div>
        <div class="pill-stat">
          <span class="label">Bank</span>
          <span class="value" id="bankValue">$28,500</span>
        </div>
        <div class="pill-stat">
          <span class="label">Ping</span>
          <span class="value" id="pingValue">24ms</span>
        </div>
      </div>

      <div class="panel dashboard">
        <div class="stack">
          <div class="character-card">
            <div class="avatar">JX</div>
            <div class="character-info">
              <h2>Jaxon Vale</h2>
              <p>Citizen ID: 8A2F-19 • Active on Violet City • Level 24</p>
              <div class="meta-row">
                <span class="meta-chip">🚓 Police Sergeant</span>
                <span class="meta-chip">📍 Mission Row</span>
                <span class="meta-chip">🟣 Purple Division</span>
              </div>
            </div>
          </div>

          <div class="panel job-menu">
            <div class="section-header">
              <div>
                <h3 class="section-title">Job Menu</h3>
                <div class="section-subtitle">Rounded action rows with purple glow</div>
              </div>
              <div class="tag" id="dutyTag">ON DUTY</div>
            </div>

            <div class="job-list" id="jobList">
              <div class="job-row active">
                <div>
                  <h4>Start Patrol</h4>
                  <p>Begin active city patrol and receive dispatch alerts.</p>
                </div>
                <div class="job-badge">SELECTED</div>
              </div>

              <div class="job-row">
                <div>
                  <h4>Open MDT</h4>
                  <p>Access incident logs, warrants, and BOLO records.</p>
                </div>
                <div class="job-badge">OPEN</div>
              </div>

              <div class="job-row">
                <div>
                  <h4>Garage Access</h4>
                  <p>Spawn an approved duty vehicle from motor pool.</p>
                </div>
                <div class="job-badge">READY</div>
              </div>

              <div class="job-row">
                <div>
                  <h4>Request Backup</h4>
                  <p>Send a silent or active request to nearby officers.</p>
                </div>
                <div class="job-badge">ALERT</div>
              </div>
            </div>
          </div>
        </div>

        <div class="panel phone">
          <div class="section-header" style="margin-bottom: 0;">
            <div>
              <h3 class="section-title">Phone / Apps</h3>
              <div class="section-subtitle">Mock NUI phone preview</div>
            </div>
            <div class="tag">NUI MODE</div>
          </div>

          <div class="phone-shell">
            <div class="phone-top">
              <span id="phoneTime">12:48</span>
              <span>📶 5G • 🔋 91%</span>
            </div>

            <div class="apps">
              <div class="app-icon" data-app="Messages">
                <span class="emoji">💬</span>
                <span>Messages</span>
              </div>
              <div class="app-icon" data-app="Dispatch">
                <span class="emoji">🚨</span>
                <span>Dispatch</span>
              </div>
              <div class="app-icon" data-app="Bank">
                <span class="emoji">🏦</span>
                <span>Bank</span>
              </div>
              <div class="app-icon" data-app="Contacts">
                <span class="emoji">👥</span>
                <span>Contacts</span>
              </div>
              <div class="app-icon" data-app="Garage">
                <span class="emoji">🚗</span>
                <span>Garage</span>
              </div>
              <div class="app-icon" data-app="Settings">
                <span class="emoji">⚙️</span>
                <span>Settings</span>
              </div>
            </div>

            <button class="btn" id="phoneNotifyBtn">Send Phone Alert</button>
          </div>
        </div>
      </div>

      <div class="panel hud">
        <div class="hud-card">
          <div class="hud-title">Health</div>
          <div class="bar"><div class="bar-fill health" id="healthBar"></div></div>
          <div class="tiny" id="healthText">84%</div>
        </div>
        <div class="hud-card">
          <div class="hud-title">Armor</div>
          <div class="bar"><div class="bar-fill armor" id="armorBar"></div></div>
          <div class="tiny" id="armorText">52%</div>
        </div>
        <div class="hud-card">
          <div class="hud-title">Stamina</div>
          <div class="bar"><div class="bar-fill stamina" id="staminaBar"></div></div>
          <div class="tiny" id="staminaText">73%</div>
        </div>
        <div class="hud-card">
          <div class="hud-title">Voice</div>
          <div class="bar"><div class="bar-fill voice" id="voiceBar"></div></div>
          <div class="tiny" id="voiceText">39%</div>
        </div>
      </div>
    </section>

    <section class="right-col">
      <div class="panel section">
        <div class="section-header">
          <div>
            <h3 class="section-title">Notifications</h3>
            <div class="section-subtitle">Fake live feed for testing layout</div>
          </div>
          <div class="tag" id="notifCount">3 ACTIVE</div>
        </div>

        <div class="notify-list" id="notifyList">
          <div class="notify">
            <strong>Dispatch Update</strong>
            <p>Suspicious vehicle flagged near Legion Square. Units advised to monitor area.</p>
          </div>
          <div class="notify">
            <strong>Banking</strong>
            <p>Salary deposit received. $850 added to main account balance.</p>
          </div>
          <div class="notify">
            <strong>Inventory</strong>
            <p>Repair kit condition updated. Durability now at 82%.</p>
          </div>
        </div>
      </div>

      <div class="panel section">
        <div class="section-header">
          <div>
            <h3 class="section-title">Control Center</h3>
            <div class="section-subtitle">Browser-only preview controls</div>
          </div>
        </div>

        <div class="quick-actions">
          <button class="btn" id="moneyBtn">Add Cash</button>
          <button class="btn secondary" id="dutyBtn">Toggle Duty</button>
          <button class="btn secondary" id="stressBtn">Use Stamina</button>
          <button class="btn" id="armorBtn">Add Armor</button>
        </div>
      </div>
    </section>
  </main>

  <script>
    const app = document.getElementById("app");
    const toastWrap = document.getElementById("toastWrap");
    const notifyList = document.getElementById("notifyList");
    const notifCount = document.getElementById("notifCount");
    const dutyTag = document.getElementById("dutyTag");

    const cashValue = document.getElementById("cashValue");
    const bankValue = document.getElementById("bankValue");
    const pingValue = document.getElementById("pingValue");

    const healthBar = document.getElementById("healthBar");
    const armorBar = document.getElementById("armorBar");
    const staminaBar = document.getElementById("staminaBar");
    const voiceBar = document.getElementById("voiceBar");

    const healthText = document.getElementById("healthText");
    const armorText = document.getElementById("armorText");
    const staminaText = document.getElementById("staminaText");
    const voiceText = document.getElementById("voiceText");

    const phoneTime = document.getElementById("phoneTime");

    let uiVisible = true;
    let onDuty = true;

    let state = {
      cash: 3240,
      bank: 28500,
      ping: 24,
      health: 84,
      armor: 52,
      stamina: 73,
      voice: 39
    };

    function formatMoney(value) {
      return "$" + value.toLocaleString();
    }

    function updateStats() {
      cashValue.textContent = formatMoney(state.cash);
      bankValue.textContent = formatMoney(state.bank);
      pingValue.textContent = `${state.ping}ms`;

      healthBar.style.width = `${state.health}%`;
      armorBar.style.width = `${state.armor}%`;
      staminaBar.style.width = `${state.stamina}%`;
      voiceBar.style.width = `${state.voice}%`;

      healthText.textContent = `${state.health}%`;
      armorText.textContent = `${state.armor}%`;
      staminaText.textContent = `${state.stamina}%`;
      voiceText.textContent = `${state.voice}%`;
    }

    function updatePhoneTime() {
      const now = new Date();
      const hours = String(now.getHours()).padStart(2, "0");
      const mins = String(now.getMinutes()).padStart(2, "0");
      phoneTime.textContent = `${hours}:${mins}`;
    }

    function updateNotifCount() {
      const count = notifyList.children.length;
      notifCount.textContent = `${count} ACTIVE`;
    }

    function createToast(title, message) {
      const toast = document.createElement("div");
      toast.className = "toast";
      toast.innerHTML = `
        <strong>${title}</strong>
        <p>${message}</p>
      `;
      toastWrap.appendChild(toast);

      setTimeout(() => {
        toast.style.opacity = "0";
        toast.style.transform = "translateY(-8px)";
        toast.style.transition = "0.2s ease";
        setTimeout(() => toast.remove(), 200);
      }, 2600);
    }

    function addNotification(title, message) {
      const notify = document.createElement("div");
      notify.className = "notify";
      notify.innerHTML = `
        <strong>${title}</strong>
        <p>${message}</p>
      `;
      notifyList.prepend(notify);

      while (notifyList.children.length > 7) {
        notifyList.removeChild(notifyList.lastElementChild);
      }

      updateNotifCount();
      createToast(title, message);
    }

    document.getElementById("notifyBtn").addEventListener("click", () => {
      addNotification("System", "Purple UI test notification pushed successfully.");
    });

    document.getElementById("phoneNotifyBtn").addEventListener("click", () => {
      addNotification("Phone Alert", "New anonymous message received on encrypted app.");
    });

    document.getElementById("moneyBtn").addEventListener("click", () => {
      state.cash += 500;
      updateStats();
      addNotification("Cash Added", "$500 added to carried cash.");
    });

    document.getElementById("payBtn").addEventListener("click", () => {
      state.bank += 850;
      updateStats();
      addNotification("Paycheck", "Salary deposit received in bank account.");
    });

    document.getElementById("healBtn").addEventListener("click", () => {
      state.health = Math.min(100, state.health + 12);
      updateStats();
      addNotification("Medical", "Health restored using med supplies.");
    });

    document.getElementById("armorBtn").addEventListener("click", () => {
      state.armor = Math.min(100, state.armor + 15);
      updateStats();
      addNotification("Armor", "Armor plates equipped.");
    });

    document.getElementById("stressBtn").addEventListener("click", () => {
      state.stamina = Math.max(0, state.stamina - 14);
      updateStats();
      addNotification("Stamina", "Stamina reduced from sprinting.");
    });

    document.getElementById("dutyBtn").addEventListener("click", () => {
      onDuty = !onDuty;
      dutyTag.textContent = onDuty ? "ON DUTY" : "OFF DUTY";
      dutyTag.style.color = onDuty ? "#c084fc" : "#fca5a5";
      dutyTag.style.background = onDuty
        ? "rgba(168, 85, 247, 0.12)"
        : "rgba(248, 113, 113, 0.12)";
      addNotification("Duty Status", onDuty ? "You are now on duty." : "You are now off duty.");
    });

    document.getElementById("toggleUiBtn").addEventListener("click", (e) => {
      uiVisible = !uiVisible;

      if (uiVisible) {
        app.classList.remove("hidden-ui");
        e.target.textContent = "Hide UI";
        createToast("UI Visible", "Preview restored.");
      } else {
        app.classList.add("hidden-ui");
        e.target.textContent = "Show UI";
        createToast("UI Hidden", "Press the same button again to restore it.");
      }
    });

    document.querySelectorAll(".item").forEach(item => {
      item.addEventListener("click", () => {
        const itemName = item.dataset.item;
        addNotification("Inventory Used", `${itemName} was selected from inventory.`);
      });
    });

    document.querySelectorAll(".app-icon").forEach(icon => {
      icon.addEventListener("click", () => {
        const appName = icon.dataset.app;
        addNotification("Phone App", `${appName} opened in preview mode.`);
      });
    });

    document.querySelectorAll(".job-row").forEach(row => {
      row.addEventListener("click", () => {
        document.querySelectorAll(".job-row").forEach(r => r.classList.remove("active"));
        row.classList.add("active");
        const title = row.querySelector("h4").textContent;
        addNotification("Job Action", `${title} selected from the job menu.`);
      });
    });

    document.getElementById("fakeSearch").addEventListener("keydown", (e) => {
      if (e.key === "Enter") {
        const value = e.target.value.trim();
        if (!value) return;
        addNotification("Search", `Preview search executed for "${value}".`);
        e.target.value = "";
      }
    });

    function randomizePing() {
      state.ping = Math.max(12, Math.min(68, state.ping + Math.floor(Math.random() * 7) - 3));
      updateStats();
    }

    function idlePulse() {
      state.voice = Math.max(20, Math.min(90, state.voice + Math.floor(Math.random() * 15) - 7));
      updateStats();
    }

    updateStats();
    updatePhoneTime();
    updateNotifCount();

    setInterval(updatePhoneTime, 1000);
    setInterval(randomizePing, 2500);
    setInterval(idlePulse, 1800);

    addNotification("Preview Ready", "Standalone purple-glow UI loaded successfully.");
  </script>
</body>
</html>
