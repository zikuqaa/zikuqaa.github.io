export default function FiveMMDTPreview() {
  const [activeTab, setActiveTab] = useState("dashboard");
  const [query, setQuery] = useState("");
  const [data, setData] = useState(seed);
  const [selected, setSelected] = useState({ profile: 1, incident: seed.incidents[0].id, warrant: seed.warrants[0].id, bolo: seed.bolos[0].id });
  const [forms, setForms] = useState({ note: "", incident: { title: "", location: "", priority: "Medium", status: "Open", units: "", summary: "", narrative: "" }, warrant: { name: "", charge: "", judge: "", bail: "", notes: "" }, bolo: { type: "Vehicle", label: "", extra: "", area: "", priority: "High", lastSeen: "", description: "" }, firearm: { model: "", serial: "", status: "Registered" } });

  const peopleFiltered = useMemo(() => data.people.filter((p) => [p.name, p.phone, p.license, p.address, p.occupation, ...p.flags].join(" ").toLowerCase().includes(query.toLowerCase())), [data.people, query]);
  const profile = data.people.find((p) => p.id === selected.profile) ?? peopleFiltered[0] ?? data.people[0];
  const incident = data.incidents.find((x) => x.id === selected.incident) ?? data.incidents[0];
  const warrant = data.warrants.find((x) => x.id === selected.warrant) ?? data.warrants[0];
  const bolo = data.bolos.find((x) => x.id === selected.bolo) ?? data.bolos[0];
  const personOptions = data.people.map((p) => String(p.id));
  const personLabels = Object.fromEntries(data.people.map((p) => [String(p.id), `${p.name} (${p.citizenId})`]));
  const filteredVehicles = data.vehicles.filter((v) => Object.values(v).join(" ").toLowerCase().includes(query.toLowerCase()));

  const log = (action, target) => setData((d) => ({ ...d, logs: [{ id: Date.now(), officer: CURRENT_OFFICER, action, target, time: now() }, ...d.logs] }));
  const patchForm = (key, value) => setForms((f) => ({ ...f, [key]: value }));
  const patchNested = (key, field, value) => setForms((f) => ({ ...f, [key]: { ...f[key], [field]: value } }));

  const addNote = () => {
    if (!profile || !forms.note.trim()) return;
    setData((d) => ({ ...d, people: d.people.map((p) => p.id === profile.id ? { ...p, notes: [{ id: Date.now(), text: forms.note.trim(), officer: CURRENT_OFFICER, time: now() }, ...p.notes] } : p) }));
    log("Added note", profile.name); patchForm("note", "");
  };
  const createIncident = () => {
    const f = forms.incident; if (!f.title.trim() || !f.location.trim()) return;
    const item = { id: idOf("INC"), title: f.title.trim(), priority: f.priority, time: "Just now", summary: f.summary.trim() || f.title.trim(), status: f.status, location: f.location.trim(), units: f.units.split(",").map((s) => s.trim()).filter(Boolean), narrative: f.narrative.trim() || "No narrative provided.", createdBy: CURRENT_OFFICER };
