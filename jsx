  };
  const createWarrant = () => {
    const f = forms.warrant; if (!f.name.trim() || !f.charge.trim()) return;
    const item = { id: idOf("WAR"), name: f.name.trim(), charge: f.charge.trim(), judge: f.judge.trim() || "Pending", active: true, issued: new Date().toISOString().slice(0, 10), bail: f.bail.trim() || "Pending", notes: f.notes.trim() || "No additional notes.", createdBy: CURRENT_OFFICER };
    setData((d) => ({ ...d, warrants: [item, ...d.warrants] })); setSelected((s) => ({ ...s, warrant: item.id })); log("Created warrant", item.id); patchForm("warrant", { name: "", charge: "", judge: "", bail: "", notes: "" });
  };
  const createBolo = () => {
    const f = forms.bolo; if (!f.label.trim() || !f.area.trim()) return;
    const item = { id: idOf("BOLO"), type: f.type, label: f.label.trim(), extra: f.extra.trim() || "No additional identifier", area: f.area.trim(), priority: f.priority, lastSeen: f.lastSeen.trim() || "Unknown", description: f.description.trim() || "No description provided.", map: { x: 20 + Math.floor(Math.random() * 60), y: 20 + Math.floor(Math.random() * 60) }, createdBy: CURRENT_OFFICER };
    setData((d) => ({ ...d, bolos: [item, ...d.bolos] })); setSelected((s) => ({ ...s, bolo: item.id })); log("Created BOLO", item.id); patchForm("bolo", { type: "Vehicle", label: "", extra: "", area: "", priority: "High", lastSeen: "", description: "" });
  };
