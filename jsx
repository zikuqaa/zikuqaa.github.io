function Select({ options, labels, ...props }) { return <select {...props} className="w-full rounded-2xl border border-white/10 bg-slate-950/60 px-4 py-3 text-sm text-white outline-none">{options.map((o) => <option key={o} value={o}>{labels?.[o] ?? o}</option>)}</select>; }
function ActionButton({ icon: Icon, children, onClick, amber }) { return <button type="button" onClick={onClick} className={`inline-flex items-center gap-2 rounded-2xl px-3 py-2 text-sm ring-1 transition ${amber ? "bg-amber-500/10 text-amber-300 ring-amber-400/20 hover:bg-amber-500/15" : "bg-sky-500/10 text-sky-300 ring-sky-400/20 hover:bg-sky-500/15"}`}>{Icon && <Icon className="h-4 w-4" />}{children}</button>; }
function SectionTitle({ icon: Icon, title, right }) { return <div className="mb-4 flex items-center justify-between gap-3"><div className="flex items-center gap-3"><div className="rounded-2xl bg-slate-800/80 p-2 text-sky-400 ring-1 ring-white/10"><Icon className="h-4 w-4" /></div><h2 className="text-lg font-semibold text-white">{title}</h2></div>{right}</div>; }
function CardButton({ active, onClick, children, amber, className = "" }) { return <button type="button" onClick={onClick} className={`w-full rounded-2xl border p-4 text-left transition ${amber ? "border-amber-400/15 bg-amber-500/5 hover:bg-amber-500/10" : "border-white/10 bg-slate-900/60 hover:bg-slate-900/80"} ${active ? "ring-2 ring-sky-400/30" : ""} ${className}`}>{children}</button>; }
function DetailPanel({ icon: Icon, title, subtitle, children, amber }) { return <div className="rounded-3xl border border-white/10 bg-white/5 p-5"><SectionTitle icon={Icon} title={title} right={subtitle ? <span className="text-xs text-slate-400">{subtitle}</span> : null} /><div className="rounded-3xl border border-white/10 bg-slate-900/70 p-5"><div className={`mb-5 inline-flex rounded-2xl p-3 ring-1 ${amber ? "bg-amber-500/15 text-amber-300 ring-amber-400/20" : "bg-sky-500/15 text-sky-300 ring-sky-400/20"}`}><Icon className="h-6 w-6" /></div>{children}</div></div>; }
