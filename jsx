      <div className="mb-6 flex flex-col gap-4 xl:flex-row xl:items-center xl:justify-between"><div><div className="text-xs uppercase tracking-[0.28em] text-sky-300/80">Mobile Data Terminal</div><h1 className="mt-2 text-3xl font-bold text-white">{tabLabel}</h1><p className="mt-1 text-sm text-slate-400">Standalone browser mockup for your FiveM MDT UI flow.</p></div><div className="w-full max-w-xl"><SearchBar value={query} onChange={setQuery} /></div></div>
      <motion.div key={activeTab} initial={{ opacity: 0, y: 10 }} animate={{ opacity: 1, y: 0 }} transition={{ duration: 0.22 }}>
        {activeTab === "dashboard" && <div className="space-y-6"><div className="grid gap-4 md:grid-cols-2 xl:grid-cols-4"><Stat label="Active Units" value="24" accent="bg-sky-400" sub="6 available / 4 on calls" /><Stat label="Open Incidents" value={String(data.incidents.length)} accent="bg-red-400" sub="Live records" /><Stat label="Active Warrants" value={String(data.warrants.filter((w) => w.active).length)} accent="bg-amber-400" sub="Created by officers" /><Stat label="BOLO Alerts" value={String(data.bolos.length)} accent="bg-emerald-400" sub="Current active notices" /></div><div className="grid gap-6 xl:grid-cols-[1.4fr_1fr]"><div className="rounded-3xl border border-white/10 bg-white/5 p-5"><SectionTitle icon={ClipboardList} title="Recent Incidents" /><div className="space-y-3">{data.incidents.map((i) => <ListCard key={i.id} item={i} active={selected.incident === i.id} onClick={() => setSelected((s) => ({ ...s, incident: i.id }))} />)}</div></div><div className="space-y-6">{incident && <DetailPanel icon={FileText} title="Incident Details" subtitle={incident.id}><div className="text-xl font-semibold text-white">{incident.title}</div><div className="mt-3 flex flex-wrap gap-2"><Badge t={priTone(incident.priority)}>{incident.priority}</Badge><Badge t="green">{incident.status}</Badge></div><div className="mt-5 grid gap-3 text-sm text-slate-300"><div className="rounded-2xl bg-white/5 p-3"><span className="text-slate-400">Location:</span> {incident.location}</div><div className="rounded-2xl bg-white/5 p-3"><span className="text-slate-400">Assigned Units:</span> {incident.units.join(", ")}</div></div><p className="mt-5 text-sm leading-6 text-slate-300">{incident.narrative}</p></DetailPanel>}<div className="rounded-3xl border border-white/10 bg-white/5 p-5"><SectionTitle icon={Radio} title="Dispatch Feed" /><div className="space-y-3">{data.calls.map((c) => <div key={c.id} className="rounded-2xl border border-white/10 bg-slate-900/60 p-3"><div className="flex items-center justify-between gap-3"><div className="text-sm font-semibold text-white">{c.code}</div><div className="text-xs text-slate-400">{c.time}</div></div><div className="mt-1 text-sm text-slate-300">{c.description}</div><div className="mt-2 flex items-center gap-2 text-xs text-slate-400"><MapPin className="h-3.5 w-3.5" /> {c.location}</div></div>)}</div></div></div></div></div>}
        {activeTab === "profiles" && <div className="grid gap-6 xl:grid-cols-[1.2fr_0.8fr]"><div className="rounded-3xl border border-white/10 bg-white/5 p-5"><SectionTitle icon={Users} title="Civilian Profiles" /><div className="space-y-3">{peopleFiltered.map((p) => <CardButton key={p.id} onClick={() => setSelected((s) => ({ ...s, profile: p.id }))} active={profile?.id === p.id}><div className="flex flex-wrap items-start justify-between gap-3"><div><div className="text-base font-semibold text-white">{p.name}</div><div className="mt-1 text-xs text-slate-400">DOB: {p.dob} • Phone: {p.phone}</div></div><div className="flex items-center gap-2"><Badge t={p.license === "Valid" ? "green" : "red"}>{p.license} License</Badge><ChevronRight className="h-4 w-4 text-slate-500" /></div></div><div className="mt-3 flex flex-wrap gap-2">{p.flags.length ? p.flags.map((f) => <Badge key={f} t="yellow">{f}</Badge>) : <Badge t="blue">No Alerts</Badge>}</div></CardButton>)}</div></div>{profile && <DetailPanel icon={User} title="Selected Profile" subtitle={profile.citizenId}><div className="flex items-center gap-4"><div className="flex h-16 w-16 items-center justify-center rounded-2xl bg-sky-500/15 text-sky-300 ring-1 ring-sky-400/20"><User className="h-8 w-8" /></div><div><div className="text-lg font-semibold text-white">{profile.name}</div><div className="text-sm text-slate-400">{profile.occupation}</div></div></div><div className="mt-5 grid grid-cols-2 gap-3 text-sm"><div className="rounded-2xl bg-white/5 p-3"><div className="text-slate-400">Driver License</div><div className="mt-1 text-white">{profile.license}</div></div><div className="rounded-2xl bg-white/5 p-3"><div className="text-slate-400">Firearm Permit</div><div className="mt-1 text-white">{profile.firearmPermit}</div></div><div className="rounded-2xl bg-white/5 p-3"><div className="text-slate-400">Active Warrants</div><div className="mt-1 text-white">{profile.activeWarrants}</div></div><div className="rounded-2xl bg-white/5 p-3"><div className="text-slate-400">Prior Charges</div><div className="mt-1 text-white">{profile.priorCharges}</div></div></div><div className="mt-5 rounded-2xl bg-white/5 p-4 text-sm text-slate-300"><div><span className="text-slate-400">Address:</span> {profile.address}</div><div className="mt-2"><span className="text-slate-400">Contact:</span> {profile.phone}</div></div><div className="mt-5 rounded-2xl border border-white/10 bg-white/5 p-4"><div className="mb-3 flex items-center justify-between"><div className="text-sm font-semibold text-white">Officer Notes</div><Badge t="blue">{profile.notes.length}</Badge></div><div className="space-y-3">{profile.notes.map((n) => <div key={n.id} className="rounded-2xl bg-slate-950/60 p-3"><div className="text-sm text-slate-200">{n.text}</div><div className="mt-2 text-xs text-slate-500">{n.officer} • {n.time}</div></div>)}</div><div className="mt-4 space-y-3"><TextArea rows={3} value={forms.note} onChange={(e) => patchForm("note", e.target.value)} placeholder="Add officer note to this person..." /><ActionButton icon={NotebookPen} onClick={addNote}>Add Note</ActionButton></div></div></DetailPanel>}</div>}
        {activeTab === "vehicles" && <div className="rounded-3xl border border-white/10 bg-white/5 p-5"><SectionTitle icon={Car} title="Vehicle Lookup" /><div className="overflow-hidden rounded-3xl border border-white/10"><table className="min-w-full divide-y divide-white/10 text-left text-sm"><thead className="bg-slate-900/80 text-slate-300"><tr><th className="px-4 py-3 font-medium">Plate</th><th className="px-4 py-3 font-medium">Model</th><th className="px-4 py-3 font-medium">Color</th><th className="px-4 py-3 font-medium">Owner</th><th className="px-4 py-3 font-medium">Status</th></tr></thead><tbody className="divide-y divide-white/5 bg-slate-950/40">{filteredVehicles.map((v) => <tr key={v.plate} className="text-slate-200 transition hover:bg-white/5"><td className="px-4 py-3 font-semibold text-white">{v.plate}</td><td className="px-4 py-3">{v.model}</td><td className="px-4 py-3">{v.color}</td><td className="px-4 py-3">{v.owner}</td><td className="px-4 py-3"><Badge t={v.status === "Clear" ? "green" : v.status === "Expired" ? "yellow" : "red"}>{v.status}</Badge></td></tr>)}</tbody></table></div></div>}
        {activeTab === "incidents" && <div className="grid gap-6 xl:grid-cols-[1.1fr_0.9fr]"><div className="space-y-6"><div className="rounded-3xl border border-white/10 bg-white/5 p-5"><SectionTitle icon={ClipboardList} title="Create Incident" right={<ActionButton icon={Plus} onClick={createIncident}>Add Incident</ActionButton>} /><div className="grid gap-3 md:grid-cols-2"><Input value={forms.incident.title} onChange={(e) => patchNested("incident", "title", e.target.value)} placeholder="Incident title" /><Input value={forms.incident.location} onChange={(e) => patchNested("incident", "location", e.target.value)} placeholder="Location" /><Select value={forms.incident.priority} onChange={(e) => patchNested("incident", "priority", e.target.value)} options={["Low", "Medium", "High", "Critical"]} /><Select value={forms.incident.status} onChange={(e) => patchNested("incident", "status", e.target.value)} options={["Open", "Investigating", "Active Search", "Closed"]} /><Input value={forms.incident.units} onChange={(e) => patchNested("incident", "units", e.target.value)} placeholder="Units (comma separated)" /><Input value={forms.incident.summary} onChange={(e) => patchNested("incident", "summary", e.target.value)} placeholder="Short summary" /></div><div className="mt-3"><TextArea rows={4} value={forms.incident.narrative} onChange={(e) => patchNested("incident", "narrative", e.target.value)} placeholder="Full narrative" /></div></div><div className="grid gap-6 lg:grid-cols-2">{data.incidents.map((i) => <ListCard key={i.id} item={i} active={incident?.id === i.id} onClick={() => setSelected((s) => ({ ...s, incident: i.id }))} />)}</div></div>{incident && <DetailPanel icon={ClipboardList} title="Incident Record" subtitle={incident.id}><div className="text-xl font-semibold text-white">{incident.title}</div><div className="mt-3 flex flex-wrap gap-2"><Badge t={priTone(incident.priority)}>{incident.priority}</Badge><Badge t="green">{incident.status}</Badge></div><div className="mt-5 grid gap-3 text-sm text-slate-300"><div className="rounded-2xl bg-white/5 p-3"><span className="text-slate-400">Location:</span> {incident.location}</div><div className="rounded-2xl bg-white/5 p-3"><span className="text-slate-400">Units:</span> {incident.units.join(", ")}</div><div className="rounded-2xl bg-white/5 p-3"><span className="text-slate-400">Created By:</span> {incident.createdBy}</div></div><p className="mt-5 text-sm leading-6 text-slate-300">{incident.narrative}</p></DetailPanel>}</div>}
        {activeTab === "warrants" && <div className="grid gap-6 xl:grid-cols-[1fr_0.9fr]"><div className="space-y-6"><div className="rounded-3xl border border-white/10 bg-white/5 p-5"><SectionTitle icon={Siren} title="Create Warrant" right={<ActionButton icon={Plus} onClick={createWarrant}>Add Warrant</ActionButton>} /><div className="grid gap-3 md:grid-cols-2"><Input value={forms.warrant.name} onChange={(e) => patchNested("warrant", "name", e.target.value)} placeholder="Subject name" /><Input value={forms.warrant.charge} onChange={(e) => patchNested("warrant", "charge", e.target.value)} placeholder="Charge" /><Input value={forms.warrant.judge} onChange={(e) => patchNested("warrant", "judge", e.target.value)} placeholder="Judge" /><Input value={forms.warrant.bail} onChange={(e) => patchNested("warrant", "bail", e.target.value)} placeholder="Bail" /></div><div className="mt-3"><TextArea rows={4} value={forms.warrant.notes} onChange={(e) => patchNested("warrant", "notes", e.target.value)} placeholder="Warrant notes" /></div></div><div className="rounded-3xl border border-white/10 bg-white/5 p-5"><SectionTitle icon={Siren} title="Warrant Registry" /><div className="space-y-3">{data.warrants.map((w) => <ListCard key={w.id} item={w} active={warrant?.id === w.id} onClick={() => setSelected((s) => ({ ...s, warrant: w.id }))} />)}</div></div></div>{warrant && <DetailPanel icon={Scale} title="Warrant Details" subtitle={warrant.id}><div className="text-xl font-semibold text-white">{warrant.name}</div><div className="mt-3 flex flex-wrap gap-2"><Badge t={warrant.active ? "red" : "green"}>{warrant.active ? "Active" : "Served"}</Badge><Badge t="yellow">{warrant.charge}</Badge></div><div className="mt-5 grid gap-3 text-sm text-slate-300"><div className="rounded-2xl bg-white/5 p-3"><span className="text-slate-400">Judge:</span> {warrant.judge}</div><div className="rounded-2xl bg-white/5 p-3"><span className="text-slate-400">Issued:</span> {warrant.issued}</div><div className="rounded-2xl bg-white/5 p-3"><span className="text-slate-400">Bail:</span> {warrant.bail}</div><div className="rounded-2xl bg-white/5 p-3"><span className="text-slate-400">Created By:</span> {warrant.createdBy}</div></div><div className="mt-5 rounded-2xl border border-amber-400/10 bg-amber-500/5 p-4 text-sm text-slate-300">{warrant.notes}</div></DetailPanel>}</div>}
        {activeTab === "bolo" && <div className="grid gap-6 xl:grid-cols-[1fr_0.95fr]"><div className="space-y-6"><div className="rounded-3xl border border-white/10 bg-white/5 p-5"><SectionTitle icon={AlertTriangle} title="Create BOLO" right={<ActionButton icon={Plus} onClick={createBolo} amber>Add BOLO</ActionButton>} /><div className="grid gap-3 md:grid-cols-2"><Select value={forms.bolo.type} onChange={(e) => patchNested("bolo", "type", e.target.value)} options={["Vehicle", "Person"]} /><Input value={forms.bolo.label} onChange={(e) => patchNested("bolo", "label", e.target.value)} placeholder="Label" /><Input value={forms.bolo.extra} onChange={(e) => patchNested("bolo", "extra", e.target.value)} placeholder="Extra / identifier" /><Input value={forms.bolo.area} onChange={(e) => patchNested("bolo", "area", e.target.value)} placeholder="Area" /><Select value={forms.bolo.priority} onChange={(e) => patchNested("bolo", "priority", e.target.value)} options={["Low", "Medium", "High", "Critical"]} /><Input value={forms.bolo.lastSeen} onChange={(e) => patchNested("bolo", "lastSeen", e.target.value)} placeholder="Last seen" /></div><div className="mt-3"><TextArea rows={4} value={forms.bolo.description} onChange={(e) => patchNested("bolo", "description", e.target.value)} placeholder="BOLO description" /></div></div><div className="grid gap-6 lg:grid-cols-2">{data.bolos.map((b) => <ListCard key={b.id} kind="bolo" item={b} active={bolo?.id === b.id} onClick={() => setSelected((s) => ({ ...s, bolo: b.id }))} />)}</div></div>{bolo && <DetailPanel icon={Route} title="BOLO Detail" subtitle={bolo.id} amber><div className="text-xl font-semibold text-white">{bolo.label}</div><div className="mt-3 flex flex-wrap gap-2"><Badge t="yellow">{bolo.type}</Badge><Badge t={priTone(bolo.priority)}>{bolo.priority}</Badge></div><div className="mt-5 grid gap-3 text-sm text-slate-300"><div className="rounded-2xl bg-white/5 p-3"><span className="text-slate-400">Area:</span> {bolo.area}</div><div className="rounded-2xl bg-white/5 p-3"><span className="text-slate-400">Last Seen:</span> {bolo.lastSeen}</div><div className="rounded-2xl bg-white/5 p-3"><span className="text-slate-400">Created By:</span> {bolo.createdBy}</div></div><p className="mt-5 text-sm leading-6 text-slate-300">{bolo.description}</p><MiniMap point={bolo.map} label={bolo.lastSeen} /></DetailPanel>}</div>}
        {activeTab === "firearms" && <div className="grid gap-6 xl:grid-cols-[1fr_1fr]"><div className="rounded-3xl border border-white/10 bg-white/5 p-5"><SectionTitle icon={FirearmIcon} title="Register Firearm" right={<ActionButton icon={Plus} onClick={registerFirearm}>Register</ActionButton>} /><div className="space-y-3"><Select value={String(profile?.id ?? data.people[0]?.id ?? "")} onChange={(e) => setSelected((s) => ({ ...s, profile: Number(e.target.value) }))} options={personOptions} labels={personLabels} /><div className="text-xs text-slate-400">Selected owner: {profile?.name}</div><Input value={forms.firearm.model} onChange={(e) => patchNested("firearm", "model", e.target.value)} placeholder="Firearm model" /><Input value={forms.firearm.serial} onChange={(e) => patchNested("firearm", "serial", e.target.value)} placeholder="Serial number" /><Select value={forms.firearm.status} onChange={(e) => patchNested("firearm", "status", e.target.value)} options={["Registered", "Impounded", "Evidence"]} /></div></div>{profile && <DetailPanel icon={FirearmIcon} title="Registered Firearms" subtitle={profile.name}><div className="space-y-3">{profile.firearms.length ? profile.firearms.map((f) => <div key={f.id} className="rounded-2xl bg-white/5 p-4"><div className="flex items-center justify-between gap-3"><div><div className="text-white font-semibold">{f.model}</div><div className="text-xs text-slate-400">Serial: {f.serial}</div></div><Badge t={f.status === "Registered" ? "green" : f.status === "Impounded" ? "yellow" : "red"}>{f.status}</Badge></div><div className="mt-2 text-xs text-slate-500">Registered by {f.officer}</div></div>) : <div className="rounded-2xl bg-white/5 p-4 text-sm text-slate-400">No firearms registered.</div>}</div></DetailPanel>}</div>}
        {activeTab === "logs" && <div className="rounded-3xl border border-white/10 bg-white/5 p-5"><SectionTitle icon={History} title="Audit Logs" right={<Badge t="blue">{data.logs.length} entries</Badge>} /><div className="space-y-3">{data.logs.map((l) => <div key={l.id} className="rounded-2xl border border-white/10 bg-slate-900/60 p-4"><div className="flex flex-wrap items-center justify-between gap-3"><div><div className="text-sm font-semibold text-white">{l.action}</div><div className="mt-1 text-sm text-slate-300">Target: {l.target}</div></div><Badge t="blue">{l.time}</Badge></div><div className="mt-3 text-xs text-slate-500">Officer: {l.officer}</div></div>)}</div></div>}
      </motion.div>
    </main>
  </div></div>;
}
