function Badge({ children, t = "slate" }) { return <span className={`rounded-full px-2.5 py-1 text-xs font-medium ${tone[t]}`}>{children}</span>; }
function Input(props) { return <input {...props} className="w-full rounded-2xl border border-white/10 bg-slate-950/60 px-4 py-3 text-sm text-white outline-none placeholder:text-slate-500" />; }
